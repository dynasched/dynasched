#ifndef DSCHED_INTERNAL_VERSIONS_H
#define DSCHED_INTERNAL_VERSIONS_H

#define DSCHED_MAJOR_VERSION @DSCHED_MAJOR_VERSION@
#define DSCHED_MINOR_VERSION @DSCHED_MINOR_VERSION@
#define DSCHED_GREEK_VERSION "@DSCHED_GREEK_VERSION@"
#define DSCHED_WANT_REPO_REV @DSCHED_WANT_REPO_REV@
#define DSCHED_REPO_REV "@DSCHED_REPO_REV@"
#ifdef DSCHED_VERSION
/* If we included the external version.h, we want the
   real version, not the stripped (no-r number) version */
#undef DSCHED_VERSION
#endif
#define DSCHED_VERSION "@DSCHED_VERSION@"

#endif
